+                        src=0,
+                        group=self._model_update_group[group_name],
+                        async_op=True,
+                    )
+                )
+                encoded_tensors.append(encoded_tensor)
+            for handle in handles:
+                handle.wait()
+            _t_nccl = _t.monotonic() - _t0
