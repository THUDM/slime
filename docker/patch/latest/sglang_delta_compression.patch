+            )
+            flat = torch.full((numel,), fill_value, dtype=param_dtype, device=self.device)
+            if p.keys_end > p.keys_start:
+                keys = packed_keys[p.keys_start : p.keys_end]
+                values = packed_values[p.values_start : p.values_end]
