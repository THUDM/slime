+class PartialWeightEncoding(str, Enum):
+    """Wire encoding for partial weight-update broadcasts (load_format in
+    ("delta", "selective")). INDICES vs BITMASK break-even density is ~3.125%:
+    INDICES costs (4+v) bytes/active, BITMASK costs ceil(n/8) + v*active bytes."""
+
+    # Per-param dense tensor; PartialWeightSpec.params is None.
+    DENSE = "dense"
+    # __packed_keys__ (int32 indices) + __packed_values__; per-param slicing in PartialWeightSpec.params.
+    SPARSE_INDICES = "sparse_indices"
+    # __packed_keys__ (uint8 LSB-first bitmask) + __packed_values__; per-param slicing in PartialWeightSpec.params.
+    SPARSE_BITMASK = "sparse_bitmask"
+
+
+@dataclass
+class PartialWeightParam:
+    """Decoding manifest entry for one parameter in a sparse partial broadcast.
+    Unused for DENSE — parent request's names/dtypes/shapes describe each param 1:1."""
+
+    name: str
+    dtype: str
+    shape: List[int]
+    # Half-open [keys_start, keys_end) slice into __packed_keys__.
+    keys_start: int
+    keys_end: int
+    # Half-open [values_start, values_end) slice into __packed_values__.
+    values_start: int
+    values_end: int
+
+
+@dataclass
+class PartialWeightSpec:
+    """Wire-encoding descriptor for a partial weight-update broadcast. Required when
+    parent request's load_format is "delta" (values applied additively) or "selective"
+    (values overwrite; NaN = unchanged sentinel)."""
+
+    encoding: PartialWeightEncoding
+    # Per-param decoding manifest. Required for sparse encodings, None for DENSE.
+    params: Optional[List[PartialWeightParam]] = None
+
+
