+    def _decode_and_apply_blob(self, blob: bytes) -> tuple[bool, str, Optional[str]]:
+        """Decode + apply one decompressed safetensors blob from the delta sender.
+        Returns ``(success, message, target_version)`` with the in-file ``current_version``.
+        Does NOT update ``self.current_weight_version`` — caller (the directory-bulk path)
+        advances it after every file is applied.
+
+        Validates ``meta.prev_version == self.current_weight_version`` so a stale or
+        out-of-order RPC is rejected.
+        """
+        from safetensors.torch import load as st_load
+
+        # Metadata lives in the safetensors header; ``st_load`` only returns tensors,
+        # so parse the header once to pull (encoding, params, version lineage).
+        hdr_len = int.from_bytes(blob[:8], "little")
+        meta = json.loads(blob[8:8 + hdr_len]).get("__metadata__", {})
+        if meta["prev_version"] != self.current_weight_version:
+            return False, (
+                f"lineage mismatch: file expects prev_version={meta['prev_version']!r}, "
+                f"receiver at {self.current_weight_version!r}"
+            ), None
+        encoding = DeltaEncoding(meta["encoding"])
+        params = [DeltaParam(**p) for p in json.loads(meta["params"])]
+
+        tensors = st_load(blob)
+        positions = tensors["__positions__"].to(self.device, non_blocking=True)
+        values = tensors["__values__"].to(self.device, non_blocking=True)
+        self._apply_delta_payload(encoding, params, positions, values)
+        return True, "ok", meta["current_version"]
+
+    def _apply_delta_from_distributed(
+        self,
+        names: List[str],
+        dtypes: List[str],
+        shapes: List[List[int]],
+        group_name: str,
+        delta: DeltaSpec,
+    ) -> tuple[bool, str]:
+        """NCCL delta receive: broadcast (__positions__, __values__) from the sender,
+        then apply via the shared ``_apply_delta_payload``. Sender's ``DeltaSpec`` carries
+        per-param decoding offsets; the broadcast tensors carry the payload."""
+        try:
+            recv: Dict[str, torch.Tensor] = {}
+            handles = []
+            for name, dtype, shape in zip(names, dtypes, shapes):
+                target_dtype = dtype if isinstance(dtype, torch.dtype) else getattr(torch, dtype)
+                t = torch.empty(shape, dtype=target_dtype, device=self.device)
+                handles.append(
+                    torch.distributed.broadcast(
+                        t, src=0, group=self._model_update_group[group_name], async_op=True
+                    )
+                )
+                recv[name] = t
+            for h in handles:
+                h.wait()
+
+            self._apply_delta_payload(delta.encoding, delta.params, recv["__positions__"], recv["__values__"])
+            return True, "ok"
+        except Exception as e:
+            error_msg = f"Failed to apply delta from distributed: {e}."
+            logger.error(error_msg)
+            return False, error_msg
+
+    def _apply_delta_dir(self, model_path: str) -> tuple[bool, str]:
+        """Disk delta receive: read every per-flush safetensors file under ``model_path``,
+        decode + apply each, then advance ``current_weight_version``.
+
+        File-level zstd decompression is auto-detected from the leading magic bytes.
+        Cross-host file visibility is the shared-FS layer's concern; if the deployment
+        lacks POSIX semantics, the trainer-side ``custom_delta_pre_push_path`` hook is
+        the place to fan out commit/reload RPCs to the engines."""
+        import time as _time
+
+        t_total_start = _time.perf_counter()
+        done_path = os.path.join(model_path, "DONE")
+        if not os.path.exists(done_path):
+            return False, f"DONE marker missing in {model_path!r}"
+        files = sorted(glob.glob(os.path.join(model_path, "*.safetensors")))
+
+        target_version: Optional[str] = None
+        t_prefetch_ms = 0.0
+        t_apply_ms = 0.0
+        n_files = len(files)
+        bytes_on_disk = 0
+        bytes_decompressed = 0
+
+        def _read_and_decompress(path: str) -> Tuple[int, bytes]:
+            with open(path, "rb") as fh:
+                blob = fh.read()
+            return len(blob), _maybe_zstd_decompress(blob)
+
+        try:
+            # Batched parallel prefetch: read + decompress ``workers`` files concurrently,
+            # then apply them before starting the next batch. Caps peak memory at
+            # ``workers × file_size`` instead of ``n_files × file_size``.
+            import concurrent.futures
+
+            workers = min(n_files, 4)
+            for i in range(0, n_files, workers):
+                t_phase = _time.perf_counter()
+                with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
+                    batch = list(pool.map(_read_and_decompress, files[i : i + workers]))
+                t_prefetch_ms += (_time.perf_counter() - t_phase) * 1000
+
+                for compressed_size, blob in batch:
+                    bytes_on_disk += compressed_size
+                    bytes_decompressed += len(blob)
+
+                    t_phase = _time.perf_counter()
+                    ok, msg, tv = self._decode_and_apply_blob(blob)
+                    t_apply_ms += (_time.perf_counter() - t_phase) * 1000
+                    if not ok:
+                        return False, msg
+                    if target_version is None:
+                        target_version = tv
+
+            assert target_version is not None
+            self.current_weight_version = target_version
+            total_ms = (_time.perf_counter() - t_total_start) * 1000
+            other_ms = total_ms - (t_prefetch_ms + t_apply_ms)
+            logger.info(
+                "[delta sync recv rank=%d gpu_id=%d v=%s] files=%d workers=%d "
+                "on_disk=%.1fMiB decompressed=%.1fMiB | "
+                "prefetch=%.2fs apply=%.2fs other=%.2fs total=%.2fs",
+                dist.get_rank(), self.gpu_id, target_version, n_files, workers,
+                bytes_on_disk / 1024 ** 2, bytes_decompressed / 1024 ** 2,
+                t_prefetch_ms / 1000, t_apply_ms / 1000,
+                other_ms / 1000, total_ms / 1000,
+            )
+            return True, f"Applied delta update to version {target_version!r}"
+        except Exception as e:
+            error_msg = f"Failed to apply delta update from disk: {e}."
+            logger.error(error_msg)
+            return False, error_msg
