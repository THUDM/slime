+class DeltaEncoding(str, Enum):
+    """Position encoding for delta weight updates (load_format=="delta").
+    User-selectable via slime's --update-weight-encoding. Choice is a
+    bandwidth/compute tradeoff over the same (__positions__, __values__) wire layout."""
+
+    # int32 absolute nonzero offsets. Lowest compute, largest payload.
+    INDICES = "indices"
+    # uint16 gap-deltas between consecutive sorted positions; uint32 fallback per
+    # param. Smaller payload, modest compute (one cumsum on apply).
+    DELTAS = "deltas"
+    # ``deltas`` with the safetensors blob wrapped in zstd L1. Smallest payload,
+    # heaviest compute. Best for shared-FS bandwidth ≤ ~300 MB/s.
+    DELTAS_ZSTD = "deltas_zstd"
+
+
+@dataclass
+class DeltaParam:
+    """Per-param decoding manifest for a delta weight update.
+
+    Position layout (``__positions__`` — uint8 byte blob shared by all encodings):
+    each param occupies the half-open byte range [pos_start, pos_end). ``pos_width``
+    is the byte width per position value — 4 for INDICES (int32 absolute offsets)
+    and DELTAS' uint32 fallback, 2 for DELTAS' uint16 case.
+
+    Value layout (``__values__`` — param-dtype, typically bf16): each param occupies
+    the half-open ELEMENT range [val_start, val_end)."""
+
+    name: str
+    dtype: str
+    shape: List[int]
+    pos_start: int
+    pos_end: int
+    pos_width: int  # 2 or 4
+    val_start: int
+    val_end: int
+
+
+@dataclass
+class DeltaSpec:
+    """Wire-encoding descriptor for one delta-sync bucket. Required when the parent
+    request's load_format is "delta"."""
+
+    encoding: DeltaEncoding
+    params: List[DeltaParam]
+
+
