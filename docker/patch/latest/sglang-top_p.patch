+
+    keep, probs_idx = _top_p_keep_mask_sorted(
+        probs, top_ks, top_ps, min_ps, need_top_p_sampling, need_min_p_sampling
+    )
+    return [
+        probs_idx[i][keep[i]].to(torch.int32) if bool(rows[i].item()) else None
+        for i in range(probs.shape[0])
+    ]
